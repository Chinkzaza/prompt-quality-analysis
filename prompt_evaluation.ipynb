# Prompt Quality Evaluation Notebook
import json
import matplotlib.pyplot as plt

# Load example prompts
with open("example_prompts.json") as f:
    data = json.load(f)

# Fake scoring metrics: length of response and 'clarity' score
scores = []
for item in data:
    clarity = len(item["response"].split()) / 10  # fake clarity metric
    scores.append({"id": item["id"], "clarity": clarity})

# Plot clarity scores
ids = [s["id"] for s in scores]
clarities = [s["clarity"] for s in scores]

plt.bar(ids, clarities)
plt.xlabel("Prompt ID")
plt.ylabel("Clarity Score")
plt.title("Prompt Clarity Analysis")
plt.show()
